# ── Meta / WhatsApp Cloud API ──────────────────────────────────────────────────
# Permanent access token from Meta Developer App (or a System User token)
WHATSAPP_TOKEN=

# Phone Number ID — found in your WhatsApp Business API dashboard (not the phone number itself)
WHATSAPP_PHONE_NUMBER_ID=

# Your WhatsApp number to receive the message — international format, digits only
# e.g. 919876543210  (91 = India country code)
WHATSAPP_TO_NUMBER=

# ── Discord ────────────────────────────────────────────────────────────────────
# Channel webhook URL (Discord → channel settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=
